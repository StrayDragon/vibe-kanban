{
  "name": "vibe-kanban",
  "version": "0.0.143",
  "private": true,
  "scripts": {
    "lint": "npm run frontend:lint && npm run backend:lint",
    "format": "cargo fmt --all && cd frontend && npm run format",
    "check": "npm run frontend:check && npm run backend:check",
    "guard:links": "node scripts/check-external-links.js",
    "guard:docs": "node scripts/check-doc-links.js",
    "guard:frontend-deps": "pnpm run frontend:audit:prod && pnpm run frontend:knip",
    "qa": "bash scripts/qa.sh",
    "dev": "export FRONTEND_PORT=$(node scripts/setup-dev-environment.js frontend) && export BACKEND_PORT=$(node scripts/setup-dev-environment.js backend) && concurrently \"npm run backend:dev:watch\" \"npm run frontend:dev\"",
    "e2e": "node scripts/run-e2e.js",
    "e2e:just-run": "node scripts/run-e2e-just-run.js",
    "e2e:just-run:headed": "VK_E2E_HEADED=1 node scripts/run-e2e-just-run.js",
    "e2e:install": "playwright install chromium",
    "e2e:test": "playwright test",
    "e2e:test:headed": "playwright test --headed",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:dev": "cd frontend && npm run dev -- --port ${FRONTEND_PORT:-3000} --host",
    "frontend:check": "cd frontend && npm run check",
    "frontend:audit:prod": "pnpm -C frontend audit --prod",
    "frontend:knip": "pnpm dlx knip --reporter compact --workspace ./frontend --dependencies --files",
    "backend:lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "backend:dev": "BACKEND_PORT=$(node scripts/setup-dev-environment.js backend) npm run backend:dev:watch",
    "backend:check": "cargo check",
    "backend:dev:watch": "DISABLE_WORKTREE_ORPHAN_CLEANUP=1 RUST_LOG=debug cargo watch -w crates -x 'run --bin server'",
    "generate-types": "cargo run --bin generate_types",
    "generate-types:check": "cargo run --bin generate_types -- --check",
    "generate-env-docs": "node scripts/generate-env-docs.js",
    "generate-env-docs:check": "node scripts/generate-env-docs.js --check",
    "prepare-db": "node scripts/prepare-db.js",
    "prepare-db:check": "node scripts/prepare-db.js --check",
    "remote:prepare-db:check": "node scripts/prepare-db.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "overrides": {
      "glob@10.4.5": "10.5.0",
      "minimatch@9.0.3": "9.0.7",
      "minimatch@9.0.5": "9.0.7"
    }
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.28.1"
}
